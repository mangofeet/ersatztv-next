{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ChannelConfig",
  "type": "object",
  "properties": {
    "ffmpeg": {
      "$ref": "#/$defs/FfmpegConfig"
    },
    "normalization": {
      "$ref": "#/$defs/NormalizationConfig"
    },
    "playout": {
      "$ref": "#/$defs/PlayoutConfig"
    }
  },
  "required": [
    "playout",
    "ffmpeg",
    "normalization"
  ],
  "$defs": {
    "AudioFormat": {
      "type": "string",
      "enum": [
        "aac",
        "ac3"
      ]
    },
    "AudioLoudnessConfig": {
      "type": "object",
      "properties": {
        "integrated_target": {
          "type": [
            "number",
            "null"
          ],
          "format": "double"
        },
        "range_target": {
          "type": [
            "number",
            "null"
          ],
          "format": "double"
        },
        "true_peak": {
          "type": [
            "number",
            "null"
          ],
          "format": "double"
        }
      }
    },
    "AudioNormalizationConfig": {
      "type": "object",
      "properties": {
        "bitrate_kbps": {
          "type": [
            "integer",
            "null"
          ],
          "format": "uint32",
          "minimum": 0
        },
        "buffer_kbps": {
          "type": [
            "integer",
            "null"
          ],
          "format": "uint32",
          "minimum": 0
        },
        "channels": {
          "type": [
            "integer",
            "null"
          ],
          "format": "uint32",
          "minimum": 0
        },
        "format": {
          "anyOf": [
            {
              "$ref": "#/$defs/AudioFormat"
            },
            {
              "type": "null"
            }
          ]
        },
        "loudness": {
          "anyOf": [
            {
              "$ref": "#/$defs/AudioLoudnessConfig"
            },
            {
              "type": "null"
            }
          ]
        },
        "normalize_loudness": {
          "type": "boolean",
          "default": false
        },
        "sample_rate_hz": {
          "type": [
            "integer",
            "null"
          ],
          "format": "uint32",
          "minimum": 0
        }
      }
    },
    "BwdifCudaOptions": {
      "type": "object",
      "properties": {
        "mode": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "additionalProperties": false
    },
    "BwdifOptions": {
      "type": "object",
      "properties": {
        "mode": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "additionalProperties": false
    },
    "DeinterlaceQsvOptions": {
      "type": "object",
      "properties": {
        "mode": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "additionalProperties": false
    },
    "DeinterlaceVaapiOptions": {
      "type": "object",
      "properties": {
        "mode": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "additionalProperties": false
    },
    "FfmpegConfig": {
      "type": "object",
      "properties": {
        "disabled_filters": {
          "type": "array",
          "default": [],
          "items": {
            "type": "string"
          }
        },
        "ffmpeg_path": {
          "type": [
            "string",
            "null"
          ],
          "default": null
        },
        "ffprobe_path": {
          "type": [
            "string",
            "null"
          ],
          "default": null
        },
        "preferred_filters": {
          "type": "array",
          "default": [],
          "items": {
            "type": "string"
          }
        },
        "reports_folder": {
          "type": [
            "string",
            "null"
          ],
          "default": null
        },
        "save_reports": {
          "type": "boolean",
          "default": false
        }
      }
    },
    "HardwareAccel": {
      "type": "string",
      "enum": [
        "amf",
        "cuda",
        "qsv",
        "rkmpp",
        "vaapi",
        "videotoolbox",
        "vulkan"
      ]
    },
    "LibplaceboOptions": {
      "type": "object",
      "properties": {
        "tonemapping": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "additionalProperties": false
    },
    "NormalizationConfig": {
      "type": "object",
      "properties": {
        "audio": {
          "$ref": "#/$defs/AudioNormalizationConfig"
        },
        "subtitle": {
          "$ref": "#/$defs/SubtitleNormalizationConfig"
        },
        "video": {
          "$ref": "#/$defs/VideoNormalizationConfig"
        }
      },
      "required": [
        "audio",
        "video"
      ]
    },
    "PlayoutConfig": {
      "type": "object",
      "properties": {
        "folder": {
          "type": "string"
        },
        "virtual_start": {
          "description": "RFC3339 formatted date/time, e.g. 2026-04-13T00:24:21.527-05:00",
          "type": [
            "string",
            "null"
          ],
          "default": null
        }
      },
      "required": [
        "folder"
      ]
    },
    "ScalingMode": {
      "type": "string",
      "enum": [
        "scale_and_pad",
        "stretch",
        "crop"
      ]
    },
    "SubtitleMode": {
      "type": "string",
      "enum": [
        "burn",
        "convert"
      ]
    },
    "SubtitleNormalizationConfig": {
      "type": "object",
      "properties": {
        "mode": {
          "$ref": "#/$defs/SubtitleMode"
        }
      }
    },
    "TonemapOpenclOptions": {
      "type": "object",
      "properties": {
        "tonemap": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "additionalProperties": false
    },
    "TonemapOptions": {
      "type": "object",
      "properties": {
        "tonemap": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "additionalProperties": false
    },
    "VaapiDriver": {
      "type": "string",
      "enum": [
        "ihd",
        "i965",
        "radeonsi"
      ]
    },
    "VideoFilterOptionsConfig": {
      "type": "object",
      "properties": {
        "bwdif": {
          "anyOf": [
            {
              "$ref": "#/$defs/BwdifOptions"
            },
            {
              "type": "null"
            }
          ]
        },
        "bwdif_cuda": {
          "anyOf": [
            {
              "$ref": "#/$defs/BwdifCudaOptions"
            },
            {
              "type": "null"
            }
          ]
        },
        "deinterlace_qsv": {
          "anyOf": [
            {
              "$ref": "#/$defs/DeinterlaceQsvOptions"
            },
            {
              "type": "null"
            }
          ]
        },
        "deinterlace_vaapi": {
          "anyOf": [
            {
              "$ref": "#/$defs/DeinterlaceVaapiOptions"
            },
            {
              "type": "null"
            }
          ]
        },
        "libplacebo": {
          "anyOf": [
            {
              "$ref": "#/$defs/LibplaceboOptions"
            },
            {
              "type": "null"
            }
          ]
        },
        "tonemap": {
          "anyOf": [
            {
              "$ref": "#/$defs/TonemapOptions"
            },
            {
              "type": "null"
            }
          ]
        },
        "tonemap_opencl": {
          "anyOf": [
            {
              "$ref": "#/$defs/TonemapOpenclOptions"
            },
            {
              "type": "null"
            }
          ]
        },
        "w3fdif": {
          "anyOf": [
            {
              "$ref": "#/$defs/W3fdifOptions"
            },
            {
              "type": "null"
            }
          ]
        },
        "yadif": {
          "anyOf": [
            {
              "$ref": "#/$defs/YadifOptions"
            },
            {
              "type": "null"
            }
          ]
        },
        "yadif_cuda": {
          "anyOf": [
            {
              "$ref": "#/$defs/YadifCudaOptions"
            },
            {
              "type": "null"
            }
          ]
        }
      },
      "additionalProperties": false
    },
    "VideoFormat": {
      "type": "string",
      "enum": [
        "h264",
        "hevc"
      ]
    },
    "VideoNormalizationConfig": {
      "type": "object",
      "properties": {
        "accel": {
          "anyOf": [
            {
              "$ref": "#/$defs/HardwareAccel"
            },
            {
              "type": "null"
            }
          ]
        },
        "bit_depth": {
          "type": [
            "integer",
            "null"
          ],
          "format": "uint8",
          "default": null,
          "maximum": 255,
          "minimum": 0
        },
        "bitrate_kbps": {
          "type": [
            "integer",
            "null"
          ],
          "format": "uint32",
          "minimum": 0
        },
        "buffer_kbps": {
          "type": [
            "integer",
            "null"
          ],
          "format": "uint32",
          "minimum": 0
        },
        "deinterlace": {
          "type": "boolean",
          "default": false
        },
        "filters": {
          "$ref": "#/$defs/VideoFilterOptionsConfig"
        },
        "format": {
          "anyOf": [
            {
              "$ref": "#/$defs/VideoFormat"
            },
            {
              "type": "null"
            }
          ]
        },
        "height": {
          "type": [
            "integer",
            "null"
          ],
          "format": "uint32",
          "minimum": 0
        },
        "scaling_mode": {
          "$ref": "#/$defs/ScalingMode"
        },
        "vaapi_device": {
          "type": [
            "string",
            "null"
          ]
        },
        "vaapi_driver": {
          "anyOf": [
            {
              "$ref": "#/$defs/VaapiDriver"
            },
            {
              "type": "null"
            }
          ]
        },
        "width": {
          "type": [
            "integer",
            "null"
          ],
          "format": "uint32",
          "minimum": 0
        }
      }
    },
    "W3fdifOptions": {
      "type": "object",
      "properties": {
        "mode": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "additionalProperties": false
    },
    "YadifCudaOptions": {
      "type": "object",
      "properties": {
        "mode": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "additionalProperties": false
    },
    "YadifOptions": {
      "type": "object",
      "properties": {
        "mode": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "additionalProperties": false
    }
  }
}
